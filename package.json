{
  "name": "@javalce/eslint-config",
  "version": "0.25.1",
  "description": "Javier's eslint configuration",
  "keywords": [
    "eslint",
    "eslint-config"
  ],
  "homepage": "https://github.com/javalce/eslint-config#readme",
  "bugs": {
    "url": "https://github.com/javalce/eslint-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/javalce/eslint-config.git"
  },
  "license": "MIT",
  "author": "Javier Valero <javalce29@gmail.com>",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./globs": {
      "types": "./dist/globs.d.mts",
      "default": "./dist/globs.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm typegen && tsdown",
    "dev": "npx @eslint/config-inspector --config eslint.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prepack": "pnpm build",
    "prepare": "husky",
    "release": "release-it",
    "release:test": "release-it --dry-run",
    "typecheck": "tsc --noEmit",
    "typegen": "tsx scripts/typegen.ts"
  },
  "lint-staged": {
    "*": "prettier -w --ignore-unknown"
  },
  "dependencies": {
    "@e18e/eslint-plugin": "^0.3.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.4.0",
    "local-pkg": "^1.1.2",
    "typescript-eslint": "^8.58.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/config-inspector": "^1.5.0",
    "@javalce/prettier-config": "^2.2.2",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/eslint": "^9.6.1",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^24.12.2",
    "eslint": "^9.39.4",
    "eslint-typegen": "^2.3.1",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "release-it": "^19.2.4",
    "svelte": "^5.55.3",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@eslint-react/eslint-plugin": "^2",
    "@next/eslint-plugin-next": "^15 || ^16",
    "@ngrx/eslint-plugin": "^20 || ^21",
    "@tanstack/eslint-plugin-query": "^5",
    "@tanstack/eslint-plugin-router": "^1",
    "@vitest/eslint-plugin": "^1",
    "angular-eslint": "^20 || ^21",
    "astro-eslint-parser": "^1",
    "eslint": "^9",
    "eslint-plugin-astro": "^1",
    "eslint-plugin-jest": "^29",
    "eslint-plugin-jsx-a11y": "^6",
    "eslint-plugin-react-hooks": "^7",
    "eslint-plugin-solid": "^0",
    "eslint-plugin-svelte": "^3",
    "eslint-plugin-testing-library": "^7",
    "eslint-plugin-vue": "^10",
    "svelte-eslint-parser": "^1",
    "typescript": "^5",
    "vue-eslint-parser": "^10"
  },
  "peerDependenciesMeta": {
    "@eslint-react/eslint-plugin": {
      "optional": true
    },
    "@next/eslint-plugin-next": {
      "optional": true
    },
    "@ngrx/eslint-plugin": {
      "optional": true
    },
    "@tanstack/eslint-plugin-query": {
      "optional": true
    },
    "@tanstack/eslint-plugin-router": {
      "optional": true
    },
    "@vitest/eslint-plugin": {
      "optional": true
    },
    "angular-eslint": {
      "optional": true
    },
    "astro-eslint-parser": {
      "optional": true
    },
    "eslint": {
      "optional": true
    },
    "eslint-plugin-astro": {
      "optional": true
    },
    "eslint-plugin-jest": {
      "optional": true
    },
    "eslint-plugin-jsx-a11y": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "eslint-plugin-solid": {
      "optional": true
    },
    "eslint-plugin-svelte": {
      "optional": true
    },
    "eslint-plugin-testing-library": {
      "optional": true
    },
    "eslint-plugin-vue": {
      "optional": true
    },
    "svelte-eslint-parser": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "vue-eslint-parser": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
